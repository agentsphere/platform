{
  "db_name": "PostgreSQL",
  "query": "SELECT wm.id, wm.workspace_id, wm.user_id, u.name as user_name,\n                      wm.role, wm.created_at\n               FROM workspace_members wm\n               JOIN users u ON u.id = wm.user_id\n               WHERE wm.workspace_id = $1\n               ORDER BY wm.created_at",
