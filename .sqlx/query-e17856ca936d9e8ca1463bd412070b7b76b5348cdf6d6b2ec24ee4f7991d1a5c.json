  "query": "\n            SELECT id, project_id, name, description, persistent_session, created_at, updated_at\n            FROM platform_commands\n            WHERE project_id = $1 OR project_id IS NULL\n            ORDER BY project_id IS NULL ASC, name ASC\n            LIMIT $2 OFFSET $3\n            ",
