  "query": "\n            SELECT id, project_id, workspace_id, name, description,\n                   persistent_session, created_at, updated_at\n            FROM platform_commands\n            WHERE project_id IS NULL AND workspace_id IS NULL\n            ORDER BY name ASC\n            LIMIT $1 OFFSET $2\n            ",
