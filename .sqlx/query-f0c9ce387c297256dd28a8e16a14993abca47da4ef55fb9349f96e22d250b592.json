  "db_name": "PostgreSQL",
  "query": "\n        SELECT p.id, p.owner_id, p.repo_path, p.default_branch, p.visibility\n        FROM projects p\n        JOIN users u ON u.id = p.owner_id\n        WHERE u.name = $1 AND p.name = $2 AND p.is_active = true\n        ",
