# Dev pod image for in-cluster Claude Code CLI development.
# Contains: Rust toolchain, Node.js 22, Playwright, Claude Code CLI,
# and all cargo tools needed by the Justfile (nextest, llvm-cov, sqlx, deny).
#
# Build:  docker build -f docker/Dockerfile.dev-pod -t platform-dev-pod:latest .
# Import: sudo ctr -a /run/k3s/containerd/containerd.sock -n k8s.io image import dev-pod.tar

FROM rust:1.93-bookworm

# System deps (git deliberately excluded — we build from source below for 2.42+ features)
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-client ca-certificates curl jq \
    pkg-config libssl-dev \
    python3 python3-pip python3-venv pipx \
    netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

# Git from source — Debian Bookworm ships 2.39 but we need ≥2.42 for `git worktree add --orphan`
RUN apt-get update && apt-get install -y --no-install-recommends \
    libcurl4-openssl-dev libexpat1-dev gettext zlib1g-dev \
    make gcc autoconf \
    && GIT_VER=2.47.2 \
    && curl -fsSL "https://mirrors.edge.kernel.org/pub/software/scm/git/git-${GIT_VER}.tar.xz" \
       -o /tmp/git.tar.xz \
    && tar -xf /tmp/git.tar.xz -C /tmp \
    && cd /tmp/git-${GIT_VER} \
    && make prefix=/usr/local -j"$(nproc)" NO_TCLTK=1 all \
    && make prefix=/usr/local NO_TCLTK=1 install \
    && cd / && rm -rf /tmp/git* \
    && apt-get purge -y --auto-remove make gcc autoconf \
    && rm -rf /var/lib/apt/lists/*

# kubectl
RUN curl -fsSL "https://dl.k8s.io/release/$(curl -sL https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" \
    -o /usr/local/bin/kubectl && chmod +x /usr/local/bin/kubectl

# Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && rm -rf /var/lib/apt/lists/*

# Rust components
RUN rustup component add rustfmt clippy llvm-tools-preview

# Cargo tools (matching Justfile / CI requirements)
# Install each separately so Docker can cache completed layers on rebuild
RUN cargo install cargo-nextest --locked
RUN cargo install cargo-llvm-cov --locked
RUN cargo install sqlx-cli --locked --no-default-features --features postgres,rustls
RUN cargo install cargo-deny --locked
RUN cargo install just --locked

# Python tools (diff-cover for `just cov-diff`) — install system-wide
RUN pip3 install --break-system-packages diff-cover

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Playwright headless Chromium (for `just test-ui-headless`)
RUN npx playwright install --with-deps chromium

# Non-root user — `claude --dangerously-skip-permissions` refuses to run as root
RUN useradd -m -s /bin/bash -u 1000 dev \
    && git config --system init.defaultBranch main
USER dev
WORKDIR /workspace
CMD ["sleep", "infinity"]
