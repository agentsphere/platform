# Full agent runtime image: agent-runner + Claude Code CLI + MCP servers
#
# Multi-stage build:
#   1. Build agent-runner from source
#   2. Assemble runtime image with all tools pre-installed

# ── Stage 1: Build agent-runner ───────────────────────────────────────────
FROM rust:1.93-slim-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY cli/agent-runner/ ./cli/agent-runner/
WORKDIR /build/cli/agent-runner
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/build/cli/agent-runner/target \
    cargo build --release && cp target/release/agent-runner /usr/local/bin/agent-runner

# ── Stage 2: Runtime image ────────────────────────────────────────────────
FROM gcr.io/kaniko-project/executor:v1.23.2 AS kaniko

FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    sudo \
  && rm -rf /var/lib/apt/lists/* \
  && ARCH=$(dpkg --print-architecture) \
  && KUBECTL_VERSION=v1.32.3 \
  && curl -sfSL "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${ARCH}/kubectl" -o kubectl \
  && curl -sfSL "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${ARCH}/kubectl.sha256" -o kubectl.sha256 \
  && echo "$(cat kubectl.sha256)  kubectl" | sha256sum -c - \
  && chmod +x kubectl && mv kubectl /usr/local/bin/kubectl && rm -f kubectl.sha256

# Kaniko executor + SSL certs from official image (no standalone binary releases)
# chown to uid 1000 so the non-root agent user can write to /kaniko/ at runtime
# (kaniko copies Dockerfile to /kaniko/Dockerfile during builds)
COPY --from=kaniko /kaniko/executor /kaniko/executor
RUN mkdir -p /kaniko/ssl/certs \
  && cp /etc/ssl/certs/ca-certificates.crt /kaniko/ssl/certs/ \
  && chown -R 1000:1000 /kaniko

# Agent-runner from build stage
COPY --from=builder /usr/local/bin/agent-runner /usr/local/bin/agent-runner

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code@1.0.16

# MCP servers
COPY mcp/ /usr/local/lib/mcp/
RUN cd /usr/local/lib/mcp && npm install --omit=dev

# Non-root user with sudo access (for installing packages at runtime)
RUN userdel -r node 2>/dev/null || true \
  && useradd -m -s /bin/bash -u 1000 agent \
  && echo "agent ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/agent \
  && chmod 0440 /etc/sudoers.d/agent
USER agent
WORKDIR /workspace

COPY --chown=agent:agent docker/entrypoint.sh /usr/local/bin/entrypoint.sh
COPY --chown=agent:agent docker/platform-build-status.sh /usr/local/bin/platform-build-status
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/platform-build-status

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
