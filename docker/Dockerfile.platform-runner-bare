# Bare agent image: minimal base for testing the auto-setup flow.
#
# Contains only Node.js, git, curl, and sudo. The platform's setup-tools init
# container will download agent-runner and install Claude CLI at pod start.
FROM gcr.io/kaniko-project/executor:v1.23.2 AS kaniko

FROM node:22-slim

# Kaniko executor from official image (no standalone binary releases)
COPY --from=kaniko /kaniko/executor /kaniko/executor

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    sudo \
  && rm -rf /var/lib/apt/lists/* \
  && mkdir -p /kaniko/ssl/certs \
  && cp /etc/ssl/certs/ca-certificates.crt /kaniko/ssl/certs/ \
  && chown -R 1000:1000 /kaniko \
  && userdel -r node 2>/dev/null || true \
  && useradd -m -s /bin/bash -u 1000 agent \
  && echo "agent ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/agent \
  && chmod 0440 /etc/sudoers.d/agent

USER agent
WORKDIR /workspace
