ARG PLATFORM_RUNNER_IMAGE=platform-runner:v1
FROM ${PLATFORM_RUNNER_IMAGE}

# Install project-specific tools and dependencies here.
# This image is used for agent sessions in this project.
#
# The base image (platform-runner) already includes:
#   - Node.js 22, git, curl, kubectl, Claude Code CLI

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    postgresql-client \
  && rm -rf /var/lib/apt/lists/*
USER agent
