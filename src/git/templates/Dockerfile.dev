ARG PLATFORM_RUNNER_IMAGE=platform-runner:latest
FROM ${PLATFORM_RUNNER_IMAGE}

# Install project-specific tools and dependencies here.
# This image is used for agent sessions in this project.
#
# Example: install Python for a Python project
#   RUN apt-get update && apt-get install -y python3 python3-pip && rm -rf /var/lib/apt/lists/*
#
# The base image (platform-runner) already includes:
#   - Node.js 22, git, curl, Claude Code CLI

USER root
RUN echo "Add your project dependencies here"
USER agent
