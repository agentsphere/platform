FROM python:3.12-slim

WORKDIR /tests

COPY requirements-test.txt .
RUN pip install --no-cache-dir -r requirements-test.txt

COPY tests-e2e/ ./tests-e2e/

# APP_HOST and APP_PORT are injected by the deploy_test executor
ENV APP_HOST=localhost
ENV APP_PORT=8080

# --timeout=10: kill any single test after 10s (requires pytest-timeout)
# -x: stop on first failure (fast CI feedback)
CMD ["pytest", "tests-e2e/", "-v", "--tb=short", "--timeout=10", "-x", "--junitxml=/tmp/test-results.xml"]
