#!/usr/bin/env bash
# Unified mock for the Claude CLI — drop-in replacement for `claude` binary.
#
# Handles all modes the platform uses:
#
#   1. setup-token     — Interactive OAuth flow (PTY). Emits banner + URL,
#                        reads auth code from stdin, emits token.
#   2. --print         — NDJSON streaming mode (agent sessions, LLM validation,
#                        token verification). Emits system.init → assistant → result.
#
# Environment variables:
#   MOCK_CLI_RESPONSE_FILE  — JSON array of response objects for --print mode.
#                             Each: { "text": "...", "tools": [...], "session_id": "..." }
#   MOCK_CLI_STATE_DIR      — Directory for tracking invocation count across calls.
#   MOCK_CLI_OAUTH_URL      — Override the OAuth URL emitted in setup-token mode.
#   MOCK_CLI_OAUTH_TOKEN    — Override the token emitted in setup-token mode.
#   MOCK_CLI_AUTH_FAIL       — Set to "true" to simulate authentication failure in --print.
#   MOCK_CLI_SLOW            — Sleep this many seconds before responding (simulate latency).
#
# Used by: platform integration tests, agent-runner tests, E2E tests.
# Location: tests/fixtures/claude-mock/claude
# Replaces: tests/fixtures/mock-claude-cli.sh (which only handled --print)

set -euo pipefail

# ---------------------------------------------------------------------------
# Parse arguments to determine mode
# ---------------------------------------------------------------------------

MODE="print"  # default
SESSION_ID="mock-session-id"
PROMPT=""
IS_RESUME=false
OUTPUT_FORMAT=""
MAX_TURNS=""
MCP_CONFIG=""
DISABLE_TOOLS=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        setup-token)
            MODE="setup-token"
            shift
            ;;
        --session-id)
            SESSION_ID="$2"
            shift 2
            ;;
        --resume)
            SESSION_ID="$2"
            IS_RESUME=true
            shift 2
            ;;
        -p)
            PROMPT="$2"
            shift 2
            ;;
        --print)
            MODE="print"
            shift
            ;;
        --output-format)
            OUTPUT_FORMAT="$2"
            shift 2
            ;;
        --max-turns)
            MAX_TURNS="$2"
            shift 2
            ;;
        --mcp-config)
            MCP_CONFIG="$2"
            shift 2
            ;;
        --tools)
            if [[ "$2" == "" ]]; then
                DISABLE_TOOLS="true"
            fi
            shift 2
            ;;
        --verbose)
            shift
            ;;
        *)
            # Treat remaining positional args as prompt
            if [[ -z "$PROMPT" ]]; then
                PROMPT="$1"
            fi
            shift
            ;;
    esac
done

# Optional latency simulation
if [[ -n "${MOCK_CLI_SLOW:-}" ]]; then
    sleep "$MOCK_CLI_SLOW"
fi

# ---------------------------------------------------------------------------
# Mode: setup-token (Interactive OAuth flow via PTY)
# ---------------------------------------------------------------------------
#
# Output format captured from real `claude setup-token` v2.1.87 via PTY.
# The platform's parsers (find_oauth_url, find_oauth_token, strip_ansi_escapes)
# expect this exact structure:
#   1. Welcome banner with version
#   2. ASCII art (dots separator, logo)
#   3. "Opening browser to sign in..." spinner
#   4. "Browser didn't open?" line with the OAuth URL
#   5. Blank line after URL
#   6. "Paste code here if prompted >" — then waits for stdin
#   7. After code: "Long-lived authentication token created successfully!"
#   8. "Your OAuth token (valid for 1 year):" line
#   9. Token on its own line: sk-ant-oat01-...
#  10. "Store this token securely." footer

if [[ "$MODE" == "setup-token" ]]; then

    OAUTH_URL="${MOCK_CLI_OAUTH_URL:-https://claude.ai/oauth/authorize?code=true&client_id=mock-client-id&response_type=code&redirect_uri=https%3A%2F%2Fplatform.claude.com%2Foauth%2Fcode%2Fcallback&scope=user%3Ainference&code_challenge=MockCodeChallenge123&code_challenge_method=S256&state=MockState456}"
    OAUTH_TOKEN="${MOCK_CLI_OAUTH_TOKEN:-sk-ant-oat01-MockTestToken_abcdefghijklmnopqrstuvwxyz1234567890-AABBCCDDEE}"

    # Phase 1: Banner + URL
    # Emit with realistic formatting (the platform strips ANSI, so plain text works
    # for the mock — but we add minimal structure that the parsers expect).
    echo "Welcome to Claude Code v2.1.87"
    echo "……………………………………………………………………………………………………………………………………………………………"
    echo ""
    echo "· Opening browser to sign in…"
    echo ""
    echo "Browser didn't open? Use the url below to sign in (c to copy)"
    echo ""
    echo "$OAUTH_URL"
    echo ""
    echo ""
    echo "Paste code here if prompted >"

    # Wait for auth code on stdin (just like the real CLI)
    read -r _code 2>/dev/null || true

    # Phase 2: Success + token
    echo ""
    echo "✓ Long-lived authentication token created successfully!"
    echo ""
    echo "Your OAuth token (valid for 1 year):"
    echo "$OAUTH_TOKEN"
    echo ""
    echo "Store this token securely. You won't be able to see it again."
    echo ""
    echo "Use this token by setting: export CLAUDE_CODE_OAUTH_TOKEN=<token>"

    exit 0
fi

# ---------------------------------------------------------------------------
# Mode: --print (NDJSON streaming — agent sessions, validation, verify-token)
# ---------------------------------------------------------------------------
#
# Emits NDJSON messages matching the Claude CLI streaming protocol:
#   system (init) → assistant (thinking) → assistant (tool_use) →
#   assistant (tool_result) → assistant (text) → result
#
# The platform reads these in:
#   - SubprocessTransport (agent sessions)
#   - run_validation / read_result_text / read_structured_result (LLM validate)
#   - run_cli_validation (verify-token via onboarding)

# Track invocation count for multi-response scenarios
STATE_DIR="${MOCK_CLI_STATE_DIR:-/tmp/mock-cli-state}"
mkdir -p "$STATE_DIR"
COUNT_FILE="$STATE_DIR/invocation-count"
COUNT=$(cat "$COUNT_FILE" 2>/dev/null || echo "0")
echo $((COUNT + 1)) > "$COUNT_FILE"

# Record invocation for test assertions
echo "$COUNT $PROMPT" >> "$STATE_DIR/invocations.log"

# Check for simulated auth failure — two mechanisms:
# 1. Explicit env var (for tests that can set env before spawn)
# 2. Token-based detection: if CLAUDE_CODE_OAUTH_TOKEN is set but doesn't
#    look like a valid token (sk-ant-oat*), simulate auth failure.
#    This mirrors real Claude CLI behavior and works through env_clear()
#    since run_cli_validation forwards CLAUDE_CODE_OAUTH_TOKEN.
if [[ "${MOCK_CLI_AUTH_FAIL:-}" == "true" ]]; then
    echo "{\"type\":\"error\",\"error\":{\"type\":\"authentication_failed\",\"message\":\"Invalid OAuth token\"}}"
    exit 1
fi
if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]] && [[ ! "${CLAUDE_CODE_OAUTH_TOKEN}" == sk-ant-oat* ]]; then
    echo "{\"type\":\"error\",\"error\":{\"type\":\"authentication_failed\",\"message\":\"Invalid or expired OAuth token\"}}"
    exit 1
fi

# Detect MCP-only mode (manager agent)
if [[ -n "${MCP_CONFIG:-}" ]] || [[ "$DISABLE_TOOLS" == "true" ]]; then
    echo '{"type":"system","subtype":"init","session_id":"'$SESSION_ID'","tools":["mcp__platform-core__list_projects","mcp__platform-core__create_project","mcp__platform-admin__list_users","mcp__platform-deploy__promote_staging"],"model":"claude-sonnet-4-20250514","claude_code_version":"1.0.0-mock"}'
    echo '{"type":"assistant","message":{"content":[{"type":"text","text":"I have access to platform management tools. How can I help?"}]},"session_id":"'$SESSION_ID'"}'
    echo '{"type":"result","subtype":"success","session_id":"'$SESSION_ID'","is_error":false,"result":"I have access to platform management tools. How can I help?","usage":{"input_tokens":100,"output_tokens":50},"total_cost_usd":0.0045,"duration_ms":500,"num_turns":1}'
    exit 0
fi

# Read response from file or use default
TEXT="Hello!"
TOOLS="[]"
RESPONSE_SESSION_ID="$SESSION_ID"

if [[ -n "${MOCK_CLI_RESPONSE_FILE:-}" ]] && [[ -f "$MOCK_CLI_RESPONSE_FILE" ]]; then
    ENTRY=$(python3 -c "
import json, sys
with open('$MOCK_CLI_RESPONSE_FILE') as f:
    data = json.load(f)
idx = $COUNT
if idx < len(data):
    print(json.dumps(data[idx]))
else:
    print(json.dumps(data[-1]))
" 2>/dev/null || echo '{"text":"Hello!","tools":[]}')
    TEXT=$(echo "$ENTRY" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('text','Hello!'))")
    TOOLS=$(echo "$ENTRY" | python3 -c "import json,sys; d=json.load(sys.stdin); print(json.dumps(d.get('tools',[])))")
    RESPONSE_SESSION_ID=$(echo "$ENTRY" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('session_id','$SESSION_ID'))" 2>/dev/null || echo "$SESSION_ID")
fi

# Helper: JSON-encode a string safely
json_str() {
    python3 -c "import json; print(json.dumps('$1'))" 2>/dev/null || echo "\"$1\""
}

TEXT_JSON=$(json_str "$TEXT")

# Emit NDJSON stream

# 1. system.init
echo "{\"type\":\"system\",\"subtype\":\"init\",\"session_id\":\"$RESPONSE_SESSION_ID\",\"tools\":[\"StructuredOutput\"],\"model\":\"claude-sonnet-4-20250514\",\"claude_code_version\":\"1.0.0-mock\"}"

# 2. assistant: thinking
echo "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"thinking\",\"thinking\":\"Let me analyze the request...\"}]},\"session_id\":\"$RESPONSE_SESSION_ID\"}"

# 3. assistant: tool_use
echo "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"name\":\"read_file\",\"input\":{\"path\":\"src/main.rs\"}}]},\"session_id\":\"$RESPONSE_SESSION_ID\"}"

# 4. assistant: tool_result
echo "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_result\",\"content\":\"file contents here\"}]},\"session_id\":\"$RESPONSE_SESSION_ID\"}"

# 5. assistant: text message
echo "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":$TEXT_JSON}]},\"session_id\":\"$RESPONSE_SESSION_ID\"}"

# 6. result with structured_output
STRUCTURED=$(python3 -c "
import json
text = $TEXT_JSON
tools = json.loads('$TOOLS')
print(json.dumps({'text': text, 'tools': tools}))
" 2>/dev/null || echo "{\"text\":$TEXT_JSON,\"tools\":$TOOLS}")

echo "{\"type\":\"result\",\"subtype\":\"success\",\"session_id\":\"$RESPONSE_SESSION_ID\",\"is_error\":false,\"result\":$TEXT_JSON,\"usage\":{\"input_tokens\":100,\"output_tokens\":50},\"total_cost_usd\":0.0045,\"duration_ms\":1234,\"num_turns\":3,\"structured_output\":$STRUCTURED}"
